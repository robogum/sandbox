# SerpAPI (https://serpapi.com/) の API キー
# このファイルをコピーして .env を作成し、値を書き換えてください
#   copy .env.example .env
SERPAPI_API_KEY=your_serpapi_api_key_here

# VALUE SERP (https://www.valueserp.com/) の API キー
VALUESERP_API_KEY=your_valueserp_api_key_here

# scrape.do (https://scrape.do/) の token
SCRAPE_DO_TOKEN=your_scrape_do_token_here
